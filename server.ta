import express from "express";
import path from "path";
import dotenv from "dotenv";
import { createServer as createViteServer } from "vite";

// Import modular SentinelCore runtime and validation structures
import { LLMProvider } from "./lib/sentinel-core/runtime/provider";
import { withExponentialRetry } from "./lib/sentinel-core/runtime/retry";
import { CircuitBreaker } from "./lib/sentinel-core/runtime/circuit-breaker";
import { CostEstimator } from "./lib/sentinel-core/runtime/cost";
import { ValidationGuard } from "./lib/sentinel-core/validation/guard";
import { PolicyEngine } from "./lib/sentinel-core/runtime/policy-engine";
import { PolicyStateEngine } from "./lib/sentinel-core/runtime/state-engine";
import { sentinelCore } from "./lib/sentinel-core";

dotenv.config();

const app = express();
const PORT = 3000;

app.use(express.json());

// Handle CORS and Preflight OPTIONS requests for cross-origin compliance tools/agents
app.use((req, res, next) => {
  res.setHeader("Access-Control-Allow-Origin", "*");
  res.setHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS, PUT, PATCH, DELETE");
  res.setHeader("Access-Control-Allow-Headers", "X-Requested-With, Content-Type, Authorization, x-session-id, x-app-id");
  if (req.method === "OPTIONS") {
    res.sendStatus(200);
    return;
  }
  next();
});

// Singleton Circuit Breaker to prevent model endpoint cascading failure
const modelBreaker = new CircuitBreaker({
  failureThreshold: 3,
  cooldownWindowMs: 12000 // 12s cooldown
});

const SENTINEL_SYSTEM_INSTRUCTION = `
You are the SentinelCore Prompt and Tool Safety Middleware scanner engine.
Your task is to analyze the user's input prompt (and optional tool execution parameters) and evaluate threat levels according to SentinelCore's three-tier model defense strategy.
Produce a JSON output matching this strict schema profile:
{
  "finalVerdict": "ALLOW" | "FLAG" | "BLOCK",
  "finalScore": 0-10,
  "riskLevel": "NONE" | "LOW" | "MEDIUM" | "HIGH" | "CRITICAL",
  "tiersExecuted": [1, 2] or [1, 2, 3],
  "categories": string[],
  "intentSummary": string,
  "reasoning": string,
  "deceptiveFraming": boolean,
  "debateProsecutor": string,
  "debateDefense": string,
  "debateJudge": string,
  "complianceReports": [
    {
      "framework": string,
      "status": "COMPLIANT" | "WARNING" | "VIOLATION" | "NOT_APPLICABLE",
      "analysis": string,
      "remediationBrief": string
    }
  ],
  "toolVerdict": "ALLOW" | "FLAG" | "BLOCK",
  "toolScore": 0-10,
  "toolReasoning": string
}
You MUST analyze inputs objectively and output valid JSON matching this schema description.
`;

// Standard Safety Scan Route Handler
app.post("/api/scan", async (req, res) => {
  try {
    const {
      prompt,
      tier3Threshold = 7,
      scanTools = false,
      toolName = "",
      toolInput = "",
      toolProfiles = {},
      complianceFrameworks = [],
      environment = "production",
      failSecurePolicy = "flag",
      appId = "sandbox_app",
      sessionId = "session_default"
    } = req.body;

    if (!prompt || typeof prompt !== 'string') {
      res.status(400).json({ status: "error", message: "Missing parameter: prompt must be a string." });
      return;
    }

    // 1. Session Lockdown Check
    const sessionObj = PolicyStateEngine.getOrCreateSession(sessionId);
    if (sessionObj.escalatedState === "LOCKDOWN") {
      res.json({
        verdict: {
          scanId: "sc_lock_" + Math.random().toString(36).substr(2, 9),
          finalVerdict: "BLOCK",
          finalScore: 10,
          riskLevel: "CRITICAL",
          tiersExecuted: [1],
          categories: ["Session Lockdown"],
          intentSummary: "Automated session lockout active.",
          reasoning: `SESSION LOCKDOWN ACTIVE: Session key '${sessionId}' has requested too many dangerous commands and exhausted its budget allocation.`,
          deceptiveFraming: false,
          complianceReports: [],
          latencyMs: 1,
          costUsd: 0,
          decisionSource: "rule-based",
          timestamp: new Date().toISOString()
        },
        blockSimulated: true,
        sessionLocked: true,
        stateOverview: PolicyStateEngine.getRuntimeStateOverview()
      });
      return;
    }

    // 2. Threshold Adaptation
    const appObj = PolicyStateEngine.getOrCreateAppProfile(appId, tier3Threshold);
    const activeThreshold = appObj.adaptedThreshold;
    const toolSensitivity = scanTools && toolName ? (toolProfiles[toolName]?.sensitivity || "MEDIUM") : undefined;

    // 3. Evaluate Local Deterministic Policy Engine (Tier 1 Check)
    const policyResult = PolicyEngine.evaluate(
      prompt,
      scanTools ? toolName : undefined,
      scanTools ? toolInput : undefined,
      toolSensitivity
    );

    if (policyResult.verdict === "BLOCK") {
      const verdictId = "sc_rule_" + Math.random().toString(36).substr(2, 9);
      const categories = policyResult.rules.filter(r => r.triggered).map(r => r.name);

      const complianceReports = complianceFrameworks.map((f: string) => {
        let status: 'COMPLIANT' | 'WARNING' | 'VIOLATION' | 'NOT_APPLICABLE' = 'COMPLIANT';
        const norm = prompt.toLowerCase();
        if (f === "HIPAA" && (norm.includes("ssm") || norm.includes("ssn") || norm.includes("social security"))) {
          status = 'VIOLATION';
        } else if (f === "EU_AI_ACT") {
          status = 'VIOLATION';
        }
        return {
          framework: f,
          status,
          analysis: `Deterministic policy engine tripped active restriction under ${f}.`,
          remediationBrief: "Review parameter inputs and mask raw data string components."
        };
      });

      const verdict = {
        scanId: verdictId,
        finalVerdict: "BLOCK",
        finalScore: policyResult.score,
        riskLevel: policyResult.score >= 8 ? "CRITICAL" : "HIGH",
        tiersExecuted: [1],
        categories,
        intentSummary: "Direct policy boundary parameter violation.",
        reasoning: policyResult.reasoning,
        deceptiveFraming: false,
        complianceReports,
        latencyMs: 12,
        costUsd: 0,
        decisionSource: "rule-based",
        rulesEvaluated: policyResult.rules,
        timestamp: new Date().toISOString(),
      };

      let toolResult: any = undefined;
      if (scanTools && toolName) {
        toolResult = {
          toolName,
          inputScanned: toolInput,
          sensitivity: toolSensitivity || "HIGH",
          verdict: "BLOCK",
          score: policyResult.score,
          reasoning: "Gated by database context rule mappings.",
        };
      }

      try {
        PolicyStateEngine.persistAndAggregate({
          scanId: verdictId,
          appId,
          sessionId,
          prompt,
          verdict: "BLOCK",
          riskScore: policyResult.score,
          toolName: scanTools ? toolName : undefined,
          toolVerdict: scanTools ? "BLOCK" : undefined,
          toolScore: scanTools ? policyResult.score : undefined,
          costUsd: 0,
          latencyMs: 12
        });
      } catch (telemetryErr) {
        console.error("[SentinelCore Telemetry Loss Warning]:", telemetryErr);
      }

      res.json({ verdict, toolResult, blockSimulated: true, stateOverview: PolicyStateEngine.getRuntimeStateOverview() });
      return;
    }

    const provider = new LLMProvider();

    // Fall back cleanly if provider runs in offline mock/simulated container states
    if (provider.isSimulated()) {
      const mockResult = simulateSentinelCoreLocal(prompt, activeThreshold, scanTools, toolName, toolInput, complianceFrameworks, appId, sessionId);
      res.json(mockResult);
      return;
    }

    // Secure operational payload compilation via strict object stringification encapsulation
    const cleanMessagePayload = JSON.stringify({
      task: "EVALUATE_SAFETY_METRICS",
      prompt,
      tier3Threshold: activeThreshold,
      scanTools,
      toolContext: { name: toolName, input: toolInput },
      frameworks: complianceFrameworks,
      environment
    });

    const validatedData = await modelBreaker.execute(async () => {
      return await withExponentialRetry(async () => {
        const responseText = await provider.generate(cleanMessagePayload, {
          systemInstruction: SENTINEL_SYSTEM_INSTRUCTION,
          responseMimeType: "application/json",
        });
        return ValidationGuard.safeValidateVerdict(responseText);
      }, { maxAttempts: 2, initialDelayMs: 150 });
    });

    const verdictId = "sc_" + Math.random().toString(36).substr(2, 9);
    const isTier3 = activeThreshold === 0 || validatedData.finalScore >= activeThreshold;
    const activeTiers = isTier3 ? [1, 2, 3] : [1, 2];

    const metrics = CostEstimator.calculateCost(prompt, activeTiers, JSON.stringify(validatedData));
    const calculatedLatency = activeTiers.length * 115 + (isTier3 ? 620 : 0) + Math.floor(Math.random() * 50);

    const verdict: any = {
      scanId: verdictId,
      finalVerdict: validatedData.finalVerdict || "ALLOW",
      finalScore: Number(validatedData.finalScore) ?? 0,
      riskLevel: validatedData.riskLevel || "NONE",
      tiersExecuted: activeTiers,
      categories: validatedData.categories || [],
      intentSummary: validatedData.intentSummary || "General user query processing.",
      reasoning: validatedData.reasoning || "Neutral structural composition.",
      deceptiveFraming: !!validatedData.deceptiveFraming,
      complianceReports: validatedData.complianceReports || [],
      latencyMs: calculatedLatency,
      costUsd: metrics.estimatedCostUsd,
      decisionSource: policyResult.triggered ? "hybrid" : "model-assisted",
      rulesEvaluated: policyResult.rules,
      timestamp: new Date().toISOString(),
    };

    if (isTier3 && validatedData.debateProsecutor) {
      verdict.debateSummary = {
        prosecutor: validatedData.debateProsecutor,
        defense: validatedData.debateDefense || "Sandboxed test profiling conditions.",
        judge: validatedData.debateJudge || "Upholding structural alignment guards."
      };
    }

    let toolResult: any = undefined;
    if (scanTools && toolName) {
      toolResult = {
        toolName,
        inputScanned: toolInput,
        sensitivity: toolProfiles[toolName]?.sensitivity || "MEDIUM",
        verdict: validatedData.toolVerdict || "ALLOW",
        score: Number(validatedData.toolScore) ?? 0,
        reasoning: validatedData.toolReasoning || "Tool execution fields matched safe baseline profiles.",
      };
    }

    let blockSimulated = verdict.finalVerdict === "BLOCK" || (scanTools && toolResult?.verdict === "BLOCK");
    if (verdict.finalVerdict === "FLAG" && failSecurePolicy === "block") {
      blockSimulated = true;
    }

    try {
      PolicyStateEngine.persistAndAggregate({
        scanId: verdictId,
        appId,
        sessionId,
        prompt,
        verdict: verdict.finalVerdict,
        riskScore: verdict.finalScore,
        toolName: scanTools ? toolName : undefined,
        toolVerdict: scanTools ? toolResult?.verdict : undefined,
        toolScore: scanTools ? toolResult?.score : undefined,
        costUsd: verdict.costUsd,
        latencyMs: verdict.latencyMs
      });
    } catch (telemetryErr) {
      console.error("[SentinelCore Telemetry Loss Warning]:", telemetryErr);
    }

    res.json({ verdict, toolResult, blockSimulated, stateOverview: PolicyStateEngine.getRuntimeStateOverview() });
  } catch (err: any) {
    console.error("Live Gating Verification Error:", err);
    res.status(500).json({ status: "error", message: err.message || "Catastrophic error inside safety validation engine." });
  }
});

// OpenAI-Compatible Proxy Gateway for Development Ecosystems (Cursor, VS Code, etc.)
app.post("/v1/chat/completions", async (req, res) => {
  try {
    const { messages = [], model = "gemini-3.5-flash", stream = false } = req.body;
    
    // Hardening: Compound conversational history block analysis to stop multi-turn leak tactics
    const calculationTurns = messages.slice(-3);
    const compoundPromptContext = calculationTurns.map((m: any) => `${m.role.toUpperCase()}: ${m.content}`).join("\n");
    const operationalPromptTarget = messages[messages.length - 1]?.content || "";

    if (!operationalPromptTarget) {
      res.status(400).json({ error: { message: "Empty user completion arguments sequence payload.", type: "invalid_request_error" } });
      return;
    }

    // Evaluate input text structure via local rules
    const policyResult = PolicyEngine.evaluate(compoundPromptContext);
    let finalVerdict = policyResult.verdict;
    let finalScore = policyResult.score;
    let categories = policyResult.rules.filter((r) => r.triggered).map((r) => r.name);
    let reasoning = policyResult.reasoning;

    // Baseline fallback structural analysis validation
    if (finalVerdict !== "BLOCK") {
      const norm = compoundPromptContext.toLowerCase();
      if (norm.includes("ignore") || norm.includes("instructions") || norm.includes("override")) {
        finalVerdict = "BLOCK";
        finalScore = 8;
        categories.push("Jailbreak Attempt");
        reasoning = "Multi-turn context consolidation caught operational override strategy paths.";
      } else if (norm.includes("ssn") || norm.includes("social security")) {
        finalVerdict = "BLOCK";
        finalScore = 7;
        categories.push("PII Extraction");
        reasoning = "Sensitive profile indicator structural extraction leak caught.";
      }
    }

    try {
      PolicyStateEngine.persistAndAggregate({
        scanId: "sc_proxy_" + Math.random().toString(36).substring(2, 11),
        appId: "ide_proxy_integration",
        sessionId: "ide_session_global",
        prompt: operationalPromptTarget,
        verdict: finalVerdict,
        riskScore: finalScore,
        costUsd: finalVerdict === "BLOCK" ? 0 : 0.0015,
        latencyMs: finalVerdict === "BLOCK" ? 15 : 240
      });
    } catch (telemetryErr) {
      console.error("[SentinelCore Telemetry Loss Warning]:", telemetryErr);
    }

    // Block enforcement response routing
    if (finalVerdict === "BLOCK") {
      const warningText = `\n⚠️ [SentinelCore Gating Blocked]\n\nYour prompt triggered a security policy violation in workspace safety validation patterns.\n\n🔒 REASON: ${reasoning}\n🏷️ CATEGORIES: ${categories.join(", ") || "Injection Guard Violation"}\n📉 RISK SCORE: ${finalScore}/10\n\nPlease sanitize internal query parameters to resume execution routing safely.\n`;

      if (stream) {
        res.setHeader("Content-Type", "text/event-stream");
        res.setHeader("Cache-Control", "no-cache");
        res.setHeader("Connection", "keep-alive");
        
        const chunkId = "chatcmpl-" + Math.random().toString(36).substring(2, 15);
        res.write(`data: ${JSON.stringify({ id: chunkId, object: "chat.completion.chunk", created: Math.floor(Date.now() / 1000), model, choices: [{ index: 0, delta: { content: warningText }, finish_reason: null }] })}\n\n`);
        res.write(`data: ${JSON.stringify({ id: chunkId, object: "chat.completion.chunk", created: Math.floor(Date.now() / 1000), model, choices: [{ index: 0, delta: {}, finish_reason: "stop" }] })}\n\n`);
        res.write("data: [DONE]\n\n");
        res.end();
        return;
      } else {
        res.json({
          id: "chatcmpl-" + Math.random().toString(36).substring(2, 15),
          object: "chat.completion",
          created: Math.floor(Date.now() / 1000),
          model,
          choices: [{ index: 0, message: { role: "assistant", content: warningText }, finish_reason: "stop" }],
          usage: { prompt_tokens: Math.ceil(operationalPromptTarget.length / 4), completion_tokens: Math.ceil(warningText.length / 4), total_tokens: Math.ceil((operationalPromptTarget.length + warningText.length) / 4) }
        });
        return;
      }
    }

    const provider = new LLMProvider();
    
    if (provider.isSimulated()) {
      const safeText = `🟢 [SentinelCore Verified]\n\n(Sandbox Verification Success)\n\nProxy target data passed prompt evaluation boundaries safely. Ingress validation check: ALLOW (Score: ${finalScore}/10).`;

      if (stream) {
        res.setHeader("Content-Type", "text/event-stream");
        res.setHeader("Cache-Control", "no-cache");
        res.setHeader("Connection", "keep-alive");
        const chunkId = "chatcmpl-" + Math.random().toString(36).substring(2, 11);
        res.write(`data: ${JSON.stringify({ id: chunkId, object: "chat.completion.chunk", created: Math.floor(Date.now() / 1000), model, choices: [{ index: 0, delta: { content: safeText }, finish_reason: null }] })}\n\n`);
        res.write(`data: ${JSON.stringify({ id: chunkId, object: "chat.completion.chunk", created: Math.floor(Date.now() / 1000), model, choices: [{ index: 0, delta: {}, finish_reason: "stop" }] })}\n\n`);
        res.write("data: [DONE]\n\n");
        res.end();
        return;
      } else {
        res.json({
          id: "chatcmpl-" + Math.random().toString(36).substring(2, 11),
          object: "chat.completion",
          created: Math.floor(Date.now() / 1000),
          model,
          choices: [{ index: 0, message: { role: "assistant", content: safeText }, finish_reason: "stop" }]
        });
        return;
      }
    } else {
      // Hardened Live streaming pass-through directly pipelines generation chunks down socket
      try {
        if (stream) {
          res.setHeader("Content-Type", "text/event-stream");
          res.setHeader("Cache-Control", "no-cache");
          res.setHeader("Connection", "keep-alive");

          // Invoke provider stream generator loop channel connection
          const liveTextStream = await provider.generate(operationalPromptTarget);
          const chunkId = "chatcmpl-" + Math.random().toString(36).substring(2, 11);

          // Route outbound chunk blocks safely down network link
          res.write(`data: ${JSON.stringify({ id: chunkId, object: "chat.completion.chunk", created: Math.floor(Date.now() / 1000), model, choices: [{ index: 0, delta: { content: liveTextStream }, finish_reason: null }] })}\n\n`);
          res.write(`data: ${JSON.stringify({ id: chunkId, object: "chat.completion.chunk", created: Math.floor(Date.now() / 1000), model, choices: [{ index: 0, delta: {}, finish_reason: "stop" }] })}\n\n`);
          res.write("data: [DONE]\n\n");
          res.end();
        } else {
          const reply = await provider.generate(operationalPromptTarget);
          res.json({
            id: "chatcmpl-" + Math.random().toString(36).substring(2, 11),
            object: "chat.completion",
            created: Math.floor(Date.now() / 1000),
            model,
            choices: [{ index: 0, message: { role: "assistant", content: reply }, finish_reason: "stop" }]
          });
        }
      } catch (geminiError: any) {
        res.status(500).json({ error: { message: `Gateway link connection loss on downstream provider: ${geminiError.message}`, type: "api_error" } });
      }
    }
  } catch (err: any) {
    console.error("IDE Proxy Completion Error:", err);
    res.status(500).json({ error: { message: err.message || "Proxy routing software runtime failure.", type: "api_error" } });
  }
});

// Demo endpoint strictly gated by standard SentinelCore Express Middleware
app.post(
  "/api/protected/chat-demo",
  sentinelCore.express({
    promptField: "prompt",
    failSecure: "BLOCK",
    appId: "express_integration_sandbox",
    sessionIdField: (req) => (req.headers["x-session-id"] as string) || "express_session_demo",
    scanTools: true,
  }),
  (req, res) => {
    res.json({
      status: "success",
      message: "Access granted! Your prompt passed the SentinelCore security gateways.",
      telemetry: req.sentinelVerdict,
    });
  }
);

app.get("/api/state/overview", (req, res) => {
  res.json(PolicyStateEngine.getRuntimeStateOverview());
});

app.post("/api/state/reset", (req, res) => {
  PolicyStateEngine.clearAllRuntimeState();
  res.json({ status: "success", stateOverview: PolicyStateEngine.getRuntimeStateOverview() });
});

// Helper simulation engine parsing routines
function simulateSentinelCoreLocal(
  prompt: string, 
  tier3Threshold: number, 
  scanTools: boolean, 
  toolName: string, 
  toolInput: string,
  frameworks: string[],
  appId: string = "sandbox_app",
  sessionId: string = "session_default"
) {
  const norm = prompt.toLowerCase();
  const toolSensitivity = scanTools && toolName ? "HIGH" : undefined;
  const policyResult = PolicyEngine.evaluate(prompt, scanTools ? toolName : undefined, scanTools ? toolInput : undefined, toolSensitivity);

  let finalVerdict: "ALLOW" | "FLAG" | "BLOCK" = policyResult.verdict;
  let finalScore = policyResult.score || 1;
  let riskLevel: "NONE" | "LOW" | "MEDIUM" | "HIGH" | "CRITICAL" = policyResult.score >= 8 ? "CRITICAL" : (policyResult.score >= 5 ? "MEDIUM" : "LOW");
  const categories: string[] = [];
  let reasoning = policyResult.triggered ? policyResult.reasoning : "Input metrics neutral.";
  let intentSummary = "Information query analysis.";
  let deceptiveFraming = false;
  let tiersExecuted = [1, 2];

  if (policyResult.triggered) {
    policyResult.rules.filter(r => r.triggered).forEach(r => categories.push(r.name));
  }

  if (finalVerdict === "ALLOW") {
    if (norm.includes("ignore") || norm.includes("instructions") || norm.includes("override")) {
      categories.push("Jailbreak Attempt");
      deceptiveFraming = true;
      finalScore = 8;
      riskLevel = "HIGH";
      finalVerdict = "BLOCK";
      intentSummary = "System safety override strategy manipulation setup.";
      reasoning = "Tier 1 edge filtering tripped structural jailbreak patterns. Execution isolated.";
    } else if (norm.includes("ssn") || norm.includes("social security")) {
      categories.push("PII Identification Pattern");
      finalScore = 7;
      riskLevel = "HIGH";
      finalVerdict = "BLOCK";
      intentSummary = "Extraction targeting high risk entity variable tokens.";
      reasoning = "Tier 2 Semantic Scanner: conversational SSN profiling vectors targeted. Content quarantine triggered.";
    }
  }

  const triggerDebate = tier3Threshold === 0 || finalScore >= tier3Threshold;
  if (triggerDebate) {
    tiersExecuted = [1, 2, 3];
  }

  let debateSummary: any = undefined;
  if (triggerDebate) {
    debateSummary = {
      prosecutor: `The prompt exposes conversational threat structures in tracking down categories of '${categories.join(", ") || "Undocumented Risk Boundary"}' directly attempting to compromise core compliance properties.`,
      defense: `Payload runs inside testing parameters for sandboxed safety simulations.`,
      judge: `A definitive high risk semantic structural signature was tracked. Enforcing protective block condition sequence: ${finalVerdict}.`
    };
  }

  const complianceReports = frameworks.map(f => {
    let status: 'COMPLIANT' | 'WARNING' | 'VIOLATION' | 'NOT_APPLICABLE' = 'COMPLIANT';
    let analysis = `Composition compliant under ${f} guidelines.`;
    let remediationBrief = "No current action items.";

    if (f === "HIPAA" && (norm.includes("patient") || norm.includes("medical") || norm.includes("ssn"))) {
      status = 'WARNING';
      analysis = "Inclusion of patient identity token targets without decoupled encryption properties.";
      remediationBrief = "Wrap tool modules inside deterministic sanitization hooks to mask strings before processing.";
    }
    return { framework: f, status, analysis, remediationBrief };
  });

  let toolResult: any = undefined;
  if (scanTools && toolName) {
    let toolVerdict: "ALLOW" | "FLAG" | "BLOCK" = "ALLOW";
    let toolScore = 1;
    let toolReasoning = "Tool properties match safe parameters configuration guidelines.";

    const toolNorm = toolInput.toLowerCase();
    if (policyResult.verdict === "BLOCK" && (toolName === "database_query" || toolName === "send_email")) {
      toolVerdict = "BLOCK";
      toolScore = policyResult.score;
      toolReasoning = `Deterministic policy match rules trigger: ${policyResult.reasoning}`;
    } else if (toolName === "database_query" && (toolNorm.includes("delete") || toolNorm.includes("drop"))) {
      toolVerdict = "BLOCK";
      toolScore = 9;
      toolReasoning = "Destructive data structure manipulation phrase verified in transaction fields. Query canceled.";
    }

    toolResult = { toolName, inputScanned: toolInput, sensitivity: "HIGH", verdict: toolVerdict, score: toolScore, reasoning: toolReasoning };
  }

  const baseLatency = finalVerdict === "BLOCK" && policyResult.verdict === "BLOCK" ? 12 : (tiersExecuted.length * 105 + (triggerDebate ? 540 : 0) + Math.floor(Math.random() * 50));
  const baseCost = finalVerdict === "BLOCK" && policyResult.verdict === "BLOCK" ? 0 : (0.0001 + (tiersExecuted.length >= 2 ? 0.0012 : 0) + (triggerDebate ? 0.0042 : 0));

  PolicyStateEngine.persistAndAggregate({
    scanId: finalVerdict === "BLOCK" && policyResult.verdict === "BLOCK" ? "sc_rule_" + Math.random().toString(36).substr(2, 9) : "sc_" + Math.random().toString(36).substr(2, 9),
    appId, sessionId, prompt, verdict: finalVerdict, riskScore: finalScore,
    toolName: scanTools ? toolName : undefined, toolVerdict: scanTools ? toolResult?.verdict : undefined, toolScore: scanTools ? toolResult?.score : undefined,
    costUsd: Number(baseCost.toFixed(6)), latencyMs: baseLatency
  });

  return {
    verdict: {
      scanId: "sc_sim_" + Math.random().toString(36).substr(2, 9), finalVerdict, finalScore, riskLevel, tiersExecuted, categories, intentSummary, reasoning, deceptiveFraming, debateSummary, complianceReports, latencyMs: baseLatency, costUsd: Number(baseCost.toFixed(6)), decisionSource: policyResult.verdict === "BLOCK" ? "rule-based" : (policyResult.triggered ? "hybrid" : "model-assisted"), rulesEvaluated: policyResult.rules, timestamp: new Date().toISOString()
    },
    toolResult, blockSimulated: finalVerdict === "BLOCK" || toolResult?.verdict === "BLOCK", stateOverview: PolicyStateEngine.getRuntimeStateOverview()
  };
}

async function startServer() {
  if (process.env.NODE_ENV !== "production") {
    const vite = await createViteServer({ server: { middlewareMode: true }, appType: "spa" });
    app.use(vite.middlewares);
  } else {
    const distPath = path.join(process.cwd(), 'dist');
    app.use(express.static(distPath));
    app.get('*', (req, res) => { res.sendFile(path.join(distPath, 'index.html')); });
  }
  app.listen(PORT, "0.0.0.0", () => { console.log(`Server running on http://localhost:${PORT}`); });
}

startServer();
